# --- Stripe ---
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Site ---
# Used for Stripe success/cancel redirect URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Resend (contact form) ---
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=re_...
# Where contact form submissions land
CONTACT_TO_EMAIL=hello@adera.design
# "From" address — must be a verified Resend sender (or use onboarding@resend.dev for dev)
CONTACT_FROM_EMAIL=noreply@adera.design
